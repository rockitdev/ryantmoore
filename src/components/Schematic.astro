// Systems Ryan connects. `logo` -> a GLYPHS key; null renders a text-only wordmark node.
// `cx`/`cy` are the node centre; `s` is the depth scale (larger/brighter = nearer the viewer).
// Positions are deliberately asymmetric — a loose downward-fanning cluster, not a row.
// The sun: the website/app at the centre of everything. The canvas is deliberately
// wide (1200 units) so the orbits have room to extend and the outer planets drift
// toward the edges on big screens instead of hugging the corona.
const C = { x: 600, y: 300 };
const R_sun = 64; // cables meet the sun's body here
const ORBIT = { inner: { rx: 300, ry: 118 }, outer: { rx: 480, ry: 172 } };

// Services that orbit the product. `logo` -> a GLYPHS key. Each sits on a tilted
// elliptical orbit at angle `deg` (0°=right, 90°=front/bottom); `s` is the depth scale
// (front-of-orbit nodes read larger/brighter/nearer). `bow` curves its cable. Asymmetric
// on purpose — a loose constellation, not a clock face.
// `dir` is which way this service's data packets travel: most feed 'in' to the product,
// but the services the hero outcomes name as destinations — bookings out to the calendar,
// orders out to the books, texts out via Twilio — flow 'out', so the diagram shows the
// two-way conversation the lede promises ("so they finally talk to each other").
const sources = [
  { name: 'HubSpot',         logo: 'hubspot',    orbit: 'outer', deg: 145, s: 1.12, bow:  20, dir: 'in' },
  { name: 'Stripe',          logo: 'stripe',     orbit: 'outer', deg: 35,  s: 1.05, bow: -18, dir: 'in' },
  { name: 'Drupal',          logo: 'drupal',     orbit: 'inner', deg: 8,   s: 0.95, bow:  16, dir: 'in' },
  { name: 'Twilio',          logo: 'twilio',     orbit: 'inner', deg: 187, s: 0.90, bow: -16, dir: 'out' },
  { name: 'Shopify',         logo: 'shopify',    orbit: 'inner', deg: 117, s: 0.88, bow: -12, dir: 'in' },
  { name: 'WordPress',       logo: 'wordpress',  orbit: 'inner', deg: 63,  s: 0.85, bow:  14, dir: 'in' },
  { name: 'QuickBooks',      logo: 'quickbooks', orbit: 'inner', deg: 262, s: 0.82, bow: -12, dir: 'out' },
  { name: 'Google Calendar', logo: 'gcal',       orbit: 'inner', deg: 318, s: 0.78, bow:  12, dir: 'out' },
  { name: 'Workiz',          logo: 'workiz',     orbit: 'outer', deg: 243, s: 0.76, bow:  14, dir: 'in' },
  { name: 'Jobber',          logo: 'jobber',     orbit: 'outer', deg: 297, s: 0.72, bow: -14, dir: 'in' },
];

const S_MIN = 0.70, S_MAX = 1.12;
type Node = (typeof sources)[number];
function geom(n: Node) {
  const o = ORBIT[n.orbit as 'inner' | 'outer'];
  const t = (n.deg * Math.PI) / 180;
  // the anchor sits exactly ON the orbit ellipse — the planet's true position
  const ax = C.x + o.rx * Math.cos(t);
  const ay = C.y + o.ry * Math.sin(t);
  const s = n.s;
  const font = 15 * s;
  const h = 64 * s;
  const hasLogo = !!n.logo;
  const markerW = hasLogo ? h * 0.5 : 13 * s;
  const padL = 16 * s, gap = 11 * s, padR = 18 * s;
  const textW = n.name.length * font * 0.6;
  const w = padL + markerW + gap + textW + padR;
  // the label card hangs just OUTSIDE its anchor (radially away from the sun), so the
  // glowing anchor node stays visible on the orbit line with the card attached to it
  const vx = ax - C.x, vy = ay - C.y;
  const vl = Math.hypot(vx, vy) || 1;
  const ux = vx / vl, uy = vy / vl;
  const off = (w / 2) * Math.abs(ux) + (h / 2) * Math.abs(uy) + 13;
  const cx = ax + ux * off;
  const cy = ay + uy * off;
  const x = cx - w / 2;
  const y = cy - h / 2;
  // nearer nodes read brighter; further ones recede into the field
  const depth = +(0.55 + 0.45 * ((s - S_MIN) / (S_MAX - S_MIN))).toFixed(3);
  const labelX = x + padL + markerW + gap;
  return { ...n, ax, ay, cx, cy, s, font, h, w, x, y, markerW, padL, gap, depth, hasLogo, labelX };
}
const N = sources.map(geom);

// each cable runs from the planet's orbit anchor inward to the sun's body, gently
// bowed so the constellation reads as cables rather than rigid spokes.
// packets travel anchor -> sun for dir:'in' cables, sun -> anchor for dir:'out'.
function cable(n: ReturnType<typeof geom>) {
  const dx = C.x - n.ax, dy = C.y - n.ay;
  const dist = Math.hypot(dx, dy) || 1;
  const ux = dx / dist, uy = dy / dist;
  const sx = n.ax + ux * 9, sy = n.ay + uy * 9; // leave the anchor dot crisp
  const ex = C.x - ux * R_sun, ey = C.y - uy * R_sun;
  const mx = (sx + ex) / 2, my = (sy + ey) / 2;
  const px = -(ey - sy), py = ex - sx;
  const len = Math.hypot(px, py) || 1;
  const qx = mx + (px / len) * n.bow, qy = my + (py / len) * n.bow;
  const r = (v: number) => v.toFixed(1);
  return `M${r(sx)},${r(sy)} Q${r(qx)},${r(qy)} ${r(ex)},${r(ey)}`;
}

// the sun's rays — hand-varied angle / length / width / opacity so the corona reads
// as a radiant star, not a uniform gear. R_ray is where rays begin (just off the body).
const R_ray = 72;
const rays = [
  { ang: 5,   len: 34, w: 4,   o: 0.80 },
  { ang: 28,  len: 18, w: 3,   o: 0.35 },
  { ang: 47,  len: 44, w: 4.5, o: 0.65 },
  { ang: 71,  len: 22, w: 3,   o: 0.45 },
  { ang: 95,  len: 38, w: 5,   o: 0.85 },
  { ang: 113, len: 16, w: 2.5, o: 0.30 },
  { ang: 138, len: 30, w: 3.5, o: 0.55 },
  { ang: 162, len: 20, w: 3,   o: 0.40 },
  { ang: 184, len: 42, w: 4.5, o: 0.70 },
  { ang: 203, len: 17, w: 2.5, o: 0.30 },
  { ang: 227, len: 36, w: 4,   o: 0.60 },
  { ang: 249, len: 24, w: 3,   o: 0.45 },
  { ang: 268, len: 46, w: 5,   o: 0.90 },
  { ang: 291, len: 19, w: 2.5, o: 0.35 },
  { ang: 315, len: 33, w: 3.5, o: 0.50 },
  { ang: 338, len: 26, w: 3,   o: 0.40 },
];

// One source of truth per cable — base line, drawn-in current line, and the GSAP packet
// all reference the same id/d. The path always runs service -> sun; `dir` tells the
// packet which way to ride it.
const cables = N.map((n, i) => ({ id: `cbl-${i}`, d: cable(n), dir: n.dir }));
const orbits = [ORBIT.inner, ORBIT.outer];
---

<svg
  class="schematic"
  viewBox="0 64 1200 488"
  role="img"
  aria-label="A solar-system diagram: a glowing core represents the client's website and app at the centre, with the services Ryan integrates (HubSpot, Stripe, Drupal, Twilio, Shopify, WordPress, QuickBooks, Google Calendar, Workiz and Jobber) orbiting it and exchanging data along glowing cables."
>
  <defs>
    <linearGradient id="flowGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#7fa0ff" />
      <stop offset="1" stop-color="#1f4fff" />
    </linearGradient>
    <radialGradient id="coreGrad" cx="38%" cy="30%" r="80%">
      <stop offset="0" stop-color="#cdddff" />
      <stop offset="0.55" stop-color="#3d6fff" />
      <stop offset="1" stop-color="#1f4fff" />
    </radialGradient>
    <!-- soft radial bloom with opacity falloff — the star's light, not a hard ring -->
    <radialGradient id="bloomGrad">
      <stop offset="0" stop-color="#cdddff" stop-opacity="0.55" />
      <stop offset="0.35" stop-color="#5a86ff" stop-opacity="0.28" />
      <stop offset="0.7" stop-color="#1f4fff" stop-opacity="0.1" />
      <stop offset="1" stop-color="#1f4fff" stop-opacity="0" />
    </radialGradient>
    <filter id="wireGlow" x="-60%" y="-60%" width="220%" height="220%">
      <feGaussianBlur stdDeviation="3" result="b" />
      <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
    </filter>
    <filter id="coreGlow" x="-120%" y="-120%" width="340%" height="340%">
      <feGaussianBlur stdDeviation="10" result="b" />
      <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
    </filter>
    <filter id="dotGlow" x="-150%" y="-150%" width="400%" height="400%">
      <feGaussianBlur stdDeviation="2.6" result="b" />
      <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
    </filter>
  </defs>

  <!-- sun corona glow -->
  <circle class="sun-halo sun-halo--wide" cx={C.x} cy={C.y} r="156" />
  <circle class="sun-halo" cx={C.x} cy={C.y} r="100" />

  <!-- tilted orbit guides -->
  {orbits.map((o) => <ellipse class="orbit-guide" cx={C.x} cy={C.y} rx={o.rx} ry={o.ry} />)}

  <!-- cables (faint base) -->
  {cables.map((c) => <path class="wire-base wire-base--cable" d={c.d} />)}

  <!-- cables (bright current) — DrawSVG draws these in on load so the diagram assembles -->
  {cables.map((c) => <path id={c.id} class="wire-flow wire-flow--cable" d={c.d} />)}

  <!-- data packets — GSAP MotionPath sends these inward along the cables to the core -->
  {cables.map((c) => <circle class="packet" data-path={`#${c.id}`} data-dir={c.dir} r="4.5" cx="0" cy="0" />)}

  <!-- planet anchors — glowing nodes that sit exactly ON their orbit line (these stay
       fixed while the label cards float, so the orbit relationship never breaks) -->
  {N.map((s) => <circle class="orbit-anchor" cx={s.ax.toFixed(1)} cy={s.ay.toFixed(1)} r={(3.4 + 2.6 * s.s).toFixed(1)} opacity={s.depth} />)}

  <!-- external system nodes (top) — solid raised panels carrying real brand marks.
       depth (opacity + scale) makes nearer nodes command attention, further ones recede -->
  {N.map((s) => (
    <g class="sch-node-g" opacity={s.depth}>
      <rect class="sch-node" x={s.x} y={s.y} width={s.w} height={s.h} rx={13 * s.s} />
      {s.hasLogo ? (
        <g class="sch-glyph" transform={`translate(${(s.x + s.padL).toFixed(1)} ${(s.cy - s.markerW / 2).toFixed(1)}) scale(${(s.markerW / GLYPHS[s.logo!].box).toFixed(4)})`}>
          {GLYPHS[s.logo!].twilio ? (
            <g transform="matrix(.937042 0 0 .937042 0 .046624)">
              <path d="M34.1 0C15.3 0 0 15.3 0 34.1s15.3 34.1 34.1 34.1C53 68.3 68.3 53 68.3 34.1S53 0 34.1 0zm0 59.3C20.3 59.3 9 48 9 34.1 9 20.3 20.3 9 34.1 9 48 9 59.3 20.3 59.3 34.1 59.3 48 48 59.3 34.1 59.3z" />
              <circle cx="42.6" cy="25.6" r="7.1" />
              <circle cx="42.6" cy="42.6" r="7.1" />
              <circle cx="25.6" cy="42.6" r="7.1" />
              <circle cx="25.6" cy="25.6" r="7.1" />
            </g>
          ) : (
            <path d={GLYPHS[s.logo!].d} />
          )}
        </g>
      ) : (
        <circle class="in-dot" cx={(s.x + s.padL + s.markerW / 2).toFixed(1)} cy={s.cy} r={(s.markerW * 0.42).toFixed(1)} />
      )}
      <text class="sch-label" x={s.labelX.toFixed(1)} y={(s.cy + s.font * 0.34).toFixed(1)} font-size={s.font.toFixed(1)} text-anchor="start">{s.name}</text>
    </g>
  ))}

  <!-- the sun: a radiant star whose hub is the website/app you run on -->
  <circle class="sun-bloom" cx={C.x} cy={C.y} r="148" fill="url(#bloomGrad)" />
  <g class="sun-rays">
    {rays.map((r) => (
      <rect
        class="sun-ray"
        x={C.x - r.w / 2}
        y={C.y - R_ray - r.len}
        width={r.w}
        height={r.len}
        rx={r.w / 2}
        opacity={r.o}
        transform={`rotate(${r.ang} ${C.x} ${C.y})`}
      />
    ))}
  </g>
  <g filter="url(#coreGlow)">
    <circle class="gear-body" cx={C.x} cy={C.y} r="62" />
  </g>
  <circle class="gear-hub" cx={C.x} cy={C.y} r="42" />
  <!-- tiny browser/app screen in the hub = your website & app -->
  <g class="core-screen">
    <rect class="core-screen__frame" x={C.x - 27} y={C.y - 21} width="54" height="42" rx="6" />
    <line class="core-screen__bar" x1={C.x - 27} y1={C.y - 9} x2={C.x + 27} y2={C.y - 9} />
    <circle class="core-screen__dot" cx={C.x - 20} cy={C.y - 15} r="1.7" />
    <circle class="core-screen__dot" cx={C.x - 14} cy={C.y - 15} r="1.7" />
    <circle class="core-screen__dot" cx={C.x - 8} cy={C.y - 15} r="1.7" />
  </g>

  <!-- the deliverable, named at the centre of it all -->
  <text class="out-label" x={C.x} y="532" text-anchor="middle">YOUR WEBSITE &amp; APPS</text>
</svg>

<script>
  // Motion is gated behind prefers-reduced-motion: no-preference, and skipped on phones
  // where the graphic is hidden (CSS, <=640px) so we don't animate an invisible element.
  // When we bail, cables stay drawn, packets stay hidden (CSS opacity: 0), nodes stay still.
  // GSAP is dynamically imported inside the gate so those visitors never download it.
  const animate =
    window.matchMedia('(prefers-reduced-motion: no-preference)').matches &&
    !window.matchMedia('(max-width: 640px)').matches;
  if (animate) {
    const [{ gsap }, { MotionPathPlugin }, { DrawSVGPlugin }] = await Promise.all([
      import('gsap'),
      import('gsap/MotionPathPlugin'),
      import('gsap/DrawSVGPlugin'),
    ]);
    gsap.registerPlugin(MotionPathPlugin, DrawSVGPlugin);

    const currents = gsap.utils.toArray<SVGPathElement>('.wire-flow--cable');
    const packets = gsap.utils.toArray<SVGCircleElement>('.packet');
    const nodes = gsap.utils.toArray<SVGGElement>('.sch-node-g');

    // SUPPORT — connectors draw in on load, so the diagram assembles rather than appears.
    gsap.set(currents, { drawSVG: '0%' });
    gsap.to(currents, { drawSVG: '100%', duration: 0.9, ease: 'power2.out', stagger: 0.08 });

    // PRIMARY — glowing data packets travel the cables continuously into / out of the core.
    // dir:'in' packets ride the path forward (service -> sun); dir:'out' packets ride it in
    // reverse (sun -> service), so the system reads as a conversation, not a sink.
    // Each packet fades in as it leaves a node and out as it lands, so the loop never snaps.
    packets.forEach((p, i) => {
      const path = p.getAttribute('data-path')!;
      const out = p.getAttribute('data-dir') === 'out';
      const dur = 2.2 + (i % 3) * 0.35;
      gsap.timeline({ repeat: -1, delay: 0.7 + i * 0.16 })
        .set(p, { opacity: 0 })
        .to(p, {
          duration: dur,
          ease: 'none',
          motionPath: { path, align: path, alignOrigin: [0.5, 0.5], start: out ? 1 : 0, end: out ? 0 : 1 },
        }, 0)
        .to(p, { opacity: 1, duration: dur * 0.18 }, 0)
        .to(p, { opacity: 0, duration: dur * 0.22 }, dur * 0.78);
    });

    // SUPPORT — gentle, staggered float so nothing is ever dead still.
    gsap.set(nodes, { transformBox: 'fill-box', transformOrigin: '50% 50%' });
    nodes.forEach((g, i) => {
      gsap.to(g, {
        y: i % 2 ? -5 : -3.5,
        scale: 1.015,
        duration: 3 + (i % 3) * 0.6,
        ease: 'sine.inOut',
        yoyo: true,
        repeat: -1,
        delay: i * 0.25,
      });
    });
  }
</script>
